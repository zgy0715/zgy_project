# ========================
# Global Environment
# ========================
OPENAI_API_KEY=sk-your-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# ========================
# PostgreSQL
# ========================
POSTGRES_DB=deepagent
POSTGRES_USER=deepagent
POSTGRES_PASSWORD=deepagent_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# RabbitMQ
# ========================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=deepagent
RABBITMQ_PASSWORD=deepagent_secret

# ========================
# MinIO
# ========================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=deepagent
MINIO_SECRET_KEY=deepagent_secret
MINIO_BUCKET=deepagent

# ========================
# JWT
# ========================
JWT_SECRET=change-this-in-production
JWT_ACCESS_EXPIRY=3600000
JWT_REFRESH_EXPIRY=604800000

# ========================
# Agent Runtime
# ========================
AGENT_RUNTIME_HOST=localhost
AGENT_RUNTIME_GRPC_PORT=50051
AGENT_RUNTIME_HTTP_PORT=8000

# ========================
# API Gateway
# ========================
API_GATEWAY_PORT=8080

# ========================
# Frontend
# ========================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
