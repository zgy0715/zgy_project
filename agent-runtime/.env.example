# Application
APP_NAME=DeepAgent Runtime
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# LLM Configuration
LLM_PROVIDER=openai
LLM_OPENAI_API_KEY=sk-your-api-key-here
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_CACHE_TTL=3600

# Database
DB_URL=postgresql://postgres:postgres@localhost:5432/deepagent
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Vector Engine
VECTOR_ENGINE_URL=http://localhost:8080
VECTOR_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIM=1536
VECTOR_INDEX_TYPE=hnsw
